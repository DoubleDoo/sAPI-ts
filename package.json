{
  "name": "sapi-ts",
  "version": "1.0.0",
  "description": "TS библиотека для использования API для продавцов аукциона Мешок",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "generate": "tsx scripts/generate-types.ts",
    "typecheck": "tsc --noEmit"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DoubleDoo/sAPI-ts.git"
  },
  "keywords": [
    "meshok",
    "api",
    "typescript"
  ],
  "author": "",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/DoubleDoo/sAPI-ts/issues"
  },
  "homepage": "https://github.com/DoubleDoo/sAPI-ts#readme",
  "dependencies": {
    "axios": "^1.18.1"
  },
  "devDependencies": {
    "openapi-typescript": "^7.13.0",
    "tsup": "^8.5.1",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3"
  }
}
